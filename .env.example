# LLM API Keys (at least one required)
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
DEEPSEEK_API_KEY=sk-your-key-here

# Which LLM to use: openai / anthropic / deepseek / newapi
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# NEWAPI (OpenAI-compatible gateway)
NEWAPI_API_KEY=sk-newapi-your-key-here
NEWAPI_BASE_URL=https://your-gateway.com/v1

# Per-caller LLM overrides (optional JSON, callers not listed use global default)
# Available callers: intent, chat, executor_synthesize, memory_extract, proactive_briefing, planner, tool_search
# LLM_CALLER_OVERRIDES={"intent":{"provider":"newapi","model":"gpt-4o-mini"},"chat":{"provider":"newapi","model":"gpt-4o"}}

# Database
DATABASE_URL=sqlite:///data/lifeos.db
CHROMA_PERSIST_DIR=./chroma_data

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=12345

# Log level
LOG_LEVEL=DEBUG
